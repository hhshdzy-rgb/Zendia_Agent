# This file is the template and is safe to commit.
# Copy it to `.env`, then put real local secrets there.

# LLM brain. Picks which model the DJ runs on.
#   claude-cli  — local Claude Code CLI subprocess (default; needs `claude` installed)
#   openai      — any OpenAI-compatible HTTP API (DeepSeek / 通义 / Kimi / Ollama / OpenAI / ...)
ZENDIA_LLM=claude-cli

# Settings for ZENDIA_LLM=openai. Ignored otherwise.
# Pick a base URL + model from your provider; key is sent as `Bearer <key>`.
#
# DeepSeek:        OPENAI_BASE_URL=https://api.deepseek.com/v1
#                  OPENAI_MODEL=deepseek-chat
# 通义千问 (Qwen): OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#                  OPENAI_MODEL=qwen-plus
# Moonshot (Kimi): OPENAI_BASE_URL=https://api.moonshot.cn/v1
#                  OPENAI_MODEL=moonshot-v1-8k
# Ollama (local):  OPENAI_BASE_URL=http://localhost:11434/v1
#                  OPENAI_MODEL=llama3.1
# OpenAI:          OPENAI_BASE_URL=https://api.openai.com/v1
#                  OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Weather (all optional). Pulls current conditions from Open-Meteo —
# no API key, free, global coverage. The DJ context block includes a
# weather line so the model can reference what's happening outside.
#
# Coordinate resolution priority:
#   1. WEATHER_LAT + WEATHER_LON below (explicit; wins if set)
#   2. Auto-detect via outbound IP geolocation (api.ipify.org -> ipapi.co).
#      City-level accuracy, no setup needed.
#   3. Skip — DJ just doesn't get a weather line.
#
# Set these manually if you want a specific spot, you're behind a VPN
# whose exit node is in the wrong city, or you don't want the IP lookup.
# WEATHER_PLACE is the label that ends up in the prompt ("Boston — ..."),
# defaults to whatever city the IP lookup returns.
WEATHER_LAT=
WEATHER_LON=
WEATHER_PLACE=

# NetEase Cloud Music.
# Optional, but recommended for tracks that require a logged-in account.
# How to fetch:
# 1. Open https://music.163.com/ in your browser and log in.
# 2. Open DevTools -> Application -> Cookies -> https://music.163.com.
# 3. Copy the value of MUSIC_U.
# 4. Paste it as: NCM_COOKIE=MUSIC_U=<value>
#
# Treat MUSIC_U as an auth token. Do not share it.
NCM_COOKIE=

# Fish Audio.
# Required for DJ voice synthesis. Without this, Zendia still runs but DJ
# messages stay text-only.
FISH_API_KEY=

# Optional custom Fish Audio voice reference id.
# Used as a fallback when the per-language ones below are not set.
FISH_VOICE_ID=

# Optional per-language voice ids. The runtime auto-detects whether the
# DJ line is mostly CJK or Latin and picks the matching id. Falls back
# to FISH_VOICE_ID, then to Fish's default voice.
# How to find a voice id:
#   fish.audio Voice Library → open a voice → URL ends with .../m/<id>/
FISH_VOICE_ID_ZH=
FISH_VOICE_ID_EN=

# Optional Fish Audio model id. Defaults to speech-1.6 when unset.
# Common choices: speech-1.6, s1, s1-pro, s2, s2-pro.
FISH_MODEL=

# Optional per-language model override. Some voices on fish.audio are
# tuned for a specific model version (the URL on the voice page shows
# both — modelId is the voice id, version=... is the model). If you set
# these, they win over FISH_MODEL for that language.
FISH_MODEL_ZH=
FISH_MODEL_EN=

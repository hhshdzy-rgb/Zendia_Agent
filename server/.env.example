# This file is the template and is safe to commit.
# Copy it to `.env`, then put real local secrets there.

# NetEase Cloud Music.
# Optional, but recommended for tracks that require a logged-in account.
# How to fetch:
# 1. Open https://music.163.com/ in your browser and log in.
# 2. Open DevTools -> Application -> Cookies -> https://music.163.com.
# 3. Copy the value of MUSIC_U.
# 4. Paste it as: NCM_COOKIE=MUSIC_U=<value>
#
# Treat MUSIC_U as an auth token. Do not share it.
NCM_COOKIE=

# Fish Audio.
# Required for DJ voice synthesis. Without this, Zendia still runs but DJ
# messages stay text-only.
FISH_API_KEY=

# Optional custom Fish Audio voice reference id.
FISH_VOICE_ID=

# Optional Fish Audio model id. Defaults to speech-1.6 when unset.
FISH_MODEL=
